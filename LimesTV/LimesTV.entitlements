<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The CarPlay UI is template-based (CPListTemplate + CPNowPlayingTemplate),
	     i.e. an audio app. An app must declare a single CarPlay app type; keeping
	     carplay-video here made CarPlay gate the template scene on head-unit video
	     support, so the list was blank on "no video" units. -->
	<key>com.apple.developer.carplay-audio</key>
	<true/>
</dict>
</plist>
